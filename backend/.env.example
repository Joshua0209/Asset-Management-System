APP_NAME=Asset Management System API
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/asset_management
CORS_ALLOWED_ORIGINS=["http://localhost:5173"]

# JWT — generate a 32+ byte random secret for production (e.g., `python -c 'import secrets; print(secrets.token_urlsafe(48))'`)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=720

# Bootstrap manager — seeded idempotently so the first manager always exists.
# Change the password before exposing the system outside the team.
BOOTSTRAP_MANAGER_EMAIL=admin@example.com
BOOTSTRAP_MANAGER_PASSWORD=ChangeMe123
BOOTSTRAP_MANAGER_NAME=Bootstrap Manager
BOOTSTRAP_MANAGER_DEPARTMENT=IT

# Local repair-image storage path; override per environment.
REPAIR_UPLOAD_DIR=uploads/repair-requests

# Rate limiting — in-memory slowapi (per-process). Phase 2 stays at ~4 QPS
# so per-worker counters are acceptable; revisit when Phase 3 lands Redis.
# Set RATE_LIMIT_ENABLED=false in CI / pytest to skip limiting entirely.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTHENTICATED=100/minute
RATE_LIMIT_ANONYMOUS=30/minute
RATE_LIMIT_IMAGES=300/minute

# CORS — JSON arrays. Defaults reflect this API's actual surface
# (no DELETE routes, no If-Match). Add origins per environment for AWS rollout.
CORS_ALLOWED_METHODS=["GET","POST","PATCH","OPTIONS"]
CORS_ALLOWED_HEADERS=["Authorization","Content-Type"]
