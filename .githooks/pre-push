#!/usr/bin/env bash
set -euo pipefail

ROOT=$(git rev-parse --show-toplevel)
VENV="$ROOT/backend/.venv/bin"

if [[ ! -x "$VENV/python" ]]; then
  echo "ERROR: virtualenv not found at $ROOT/backend/.venv — run setup first" >&2
  exit 1
fi

echo "╔══════════════════════════════════════╗"
echo "║   CI gate — running before push      ║"
echo "╚══════════════════════════════════════╝"

echo ""
echo "▶ backend: ruff"
"$VENV/ruff" check "$ROOT/backend"

echo "▶ backend: mypy"
"$VENV/mypy" --config-file "$ROOT/backend/pyproject.toml" "$ROOT/backend/app"

echo "▶ backend: pytest"
# -n auto: parallelise across CPU cores. Worker safety relies on (a) the
# module-scoped in-memory SQLite engine in tests/conftest.py — each worker
# process gets its own _TEST_ENGINE — and (b) repair-request/image IDs being
# UUIDs, so the shared REPAIR_UPLOAD_DIR can't see filename collisions.
# --dist=loadfile keeps tests from the same file on the same worker.
"$VENV/pytest" -n auto --dist=loadfile --tb=short -q "$ROOT/backend"

echo ""
echo "▶ frontend: eslint"
(cd "$ROOT/frontend" && npm run lint --silent)

echo "▶ frontend: typecheck"
(cd "$ROOT/frontend" && npm run typecheck --silent)

echo "▶ frontend: vitest"
(cd "$ROOT/frontend" && npm run test --silent)

echo ""
echo "✓ All CI checks passed — push allowed."
